<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.QuizSanteControllerArij"
      spacing="14"
      style="-fx-background-color:white;
             -fx-border-radius:10;
             -fx-background-radius:10;
             -fx-padding:20;
             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.12),8,0,0,2);">

    <!-- ── HEADER ─────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🧠 Quiz Santé du Jour"
               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1565c0;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="difficultyBadge" text="Facile"
               style="-fx-background-color:#4CAF50;-fx-text-fill:white;
                      -fx-padding:4 12;-fx-background-radius:12;
                      -fx-font-size:11px;-fx-font-weight:bold;"/>
    </HBox>

    <!-- ── PROGRESS ───────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ProgressBar fx:id="progressBar" prefHeight="6" HBox.hgrow="ALWAYS"/>
        <Label fx:id="progressLabel" text="Question 1/5"
               style="-fx-font-size:11px;-fx-text-fill:#888;"/>
    </HBox>

    <!-- ── LOADING ────────────────────────────────────────────── -->
    <VBox fx:id="loadingBox" alignment="CENTER" spacing="8" prefHeight="120">
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="50" prefHeight="50"/>
        <Label text="Chargement du quiz..." style="-fx-font-size:12px;-fx-text-fill:#888;"/>
    </VBox>

    <!-- ── QUIZ CONTENT ───────────────────────────────────────── -->
    <VBox fx:id="quizContent" spacing="12" visible="false" managed="false">

        <!-- Question -->
        <Label fx:id="questionLabel" text=""
               wrapText="true"
               style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1a1a1a;
                      -fx-background-color:#f4f6fb;-fx-padding:14;
                      -fx-border-radius:8;-fx-background-radius:8;"/>

        <!-- Réponses -->
        <VBox fx:id="reponsesBox" spacing="8"/>

        <!-- Feedback -->
        <HBox fx:id="feedbackBox" spacing="10" alignment="CENTER_LEFT"
              visible="false" managed="false"
              style="-fx-background-color:#f9f9f9;-fx-padding:10;
                     -fx-border-radius:6;-fx-background-radius:6;">
            <Label fx:id="feedbackLabel" text="✅ Correct !"
                   style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#2e7d32;"/>
            <Label fx:id="bonneReponseLabel" text=""
                   wrapText="true"
                   style="-fx-font-size:12px;-fx-text-fill:#c62828;"
                   visible="false" managed="false"/>
        </HBox>

        <!-- Bouton Suivante -->
        <Button fx:id="btnSuivante" text="Question suivante →"
                maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-font-size:13px;-fx-padding:10 20;
                       -fx-background-color:#1976d2;-fx-text-fill:white;
                       -fx-background-radius:7;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </VBox>

    <!-- ── SCORE PANEL ────────────────────────────────────────── -->
    <VBox fx:id="scorePanel" spacing="12" alignment="CENTER"
          visible="false" managed="false"
          style="-fx-background-color:#f4f6fb;-fx-padding:20;
                 -fx-border-radius:8;-fx-background-radius:8;">
        <Label fx:id="scoreLabel" text="Vous avez 5/5 bonnes réponses !"
               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1565c0;"/>
        <ProgressBar fx:id="scoreProgressBar" prefHeight="8" maxWidth="Infinity"/>
        <Label fx:id="messageLabel" text="" wrapText="true"
               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#2e7d32;"/>
        <Button fx:id="btnRejouer" text="🔄 Nouveau Quiz"
                maxWidth="Infinity"
                style="-fx-font-size:13px;-fx-padding:10 20;
                       -fx-background-color:#4CAF50;-fx-text-fill:white;
                       -fx-background-radius:7;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </VBox>

</VBox>
