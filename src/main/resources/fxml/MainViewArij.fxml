<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.MainControllerArij"
            stylesheets="/css/arij-styles.css"
            prefWidth="1280" prefHeight="800">

    <left>
        <VBox styleClass="sidebar" prefWidth="240" spacing="0">
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-background-color:linear-gradient(to bottom, #0f5fd4, #197bff); -fx-padding:22 16 18 16;">
                <HBox alignment="CENTER" spacing="0">
                    <Label text="💊" style="-fx-font-size:28px;"/>
                    <Label text="🕐" style="-fx-font-size:20px; -fx-translate-x:-6; -fx-translate-y:5;"/>
                </HBox>
                <Label text="MedTime" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:white;"/>
                <Label text="Plateforme medicale" style="-fx-font-size:10px; -fx-text-fill:#bfdbfe;"/>
            </VBox>

            <Separator styleClass="sidebar-sep"/>

            <Label text="NAVIGATION"
                   style="-fx-font-size:10px; -fx-font-weight:bold; -fx-text-fill:#93c5fd; -fx-padding:16 20 6 20;"/>

            <VBox spacing="4" style="-fx-padding:0 12 12 12;">
                <Button fx:id="btnSideDashboard"
                        text="  🏠  Tableau de bord"
                        styleClass="nav-btn,nav-btn-active"
                        onAction="#showDashboardView"
                        maxWidth="Infinity"/>

                <Button fx:id="btnModuleConsultation"
                        text="  🩺  Consultation en ligne"
                        styleClass="nav-btn"
                        onAction="#showConsultationHubs"
                        maxWidth="Infinity"/>

                <Button fx:id="btnModuleMarket"
                        text="  💊  Produits Pharmaceutiques"
                        styleClass="nav-btn"
                        onAction="#showMarketHubs"
                        maxWidth="Infinity"/>

                <Button fx:id="btnModuleForum"
                        text="  📰  Forum Medical"
                        styleClass="nav-btn"
                        onAction="#showForumHubs"
                        maxWidth="Infinity"/>

                <Button fx:id="btnUsers"
                        text="  Users"
                        styleClass="nav-btn"
                        onAction="#showUsers"
                        maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator styleClass="sidebar-sep"/>

            <HBox styleClass="sidebar-footer" alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color:#0d5fc4;">
                <padding><Insets top="14" bottom="18" left="14" right="14"/></padding>
                <StackPane styleClass="avatar-wrap">
                    <Label fx:id="avatarLabel" text="U" styleClass="avatar-label"/>
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="footerNameLabel" text="Utilisateur" styleClass="footer-name"/>
                    <Label fx:id="footerRoleLabel" text="Patient" styleClass="footer-role"/>
                </VBox>
                <Button text="🔔" styleClass="logout-btn" onAction="#showNotifications"
                        style="-fx-font-size:16px; -fx-text-fill:#bfdbfe;"/>
                <Button text="⏻" styleClass="logout-btn" onAction="#handleLogout"
                        style="-fx-text-fill:#fca5a5;"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color:#f5f7fa;"/>
    </center>

</BorderPane>
