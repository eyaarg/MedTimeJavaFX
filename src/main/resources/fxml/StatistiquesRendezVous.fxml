<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="esprit.fx.controllers.StatistiquesRendezVousController"
            prefHeight="700.0" prefWidth="1000.0">
    <VBox spacing="20" alignment="CENTER" AnchorPane.topAnchor="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">
        <Label text="Statistiques des Rendez-Vous" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        
        <HBox spacing="20" alignment="CENTER">
            <VBox alignment="CENTER" style="-fx-background-color: #f0f0f0; -fx-padding: 10; -fx-background-radius: 5;">
                <Label text="Taux de Confirmation" style="-fx-font-weight: bold;"/>
                <Label fx:id="tauxConfirmationLabel" text="0%" style="-fx-font-size: 24px; -fx-text-fill: #2ecc71;"/>
            </VBox>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <!-- Nombre de RDV par mois -->
            <BarChart fx:id="rdvParMoisChart" title="RDV par Mois" HBox.hgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Mois" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Nombre de RDV" />
                </yAxis>
            </BarChart>

            <!-- Nombre de RDV par statut -->
            <PieChart fx:id="rdvParStatutChart" title="RDV par Statut" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <!-- Nombre de RDV par médecin -->
            <BarChart fx:id="rdvParMedecinChart" title="RDV par Médecin" HBox.hgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis label="Médecin" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Nombre de RDV" />
                </yAxis>
            </BarChart>
        </HBox>
    </VBox>
</AnchorPane>
