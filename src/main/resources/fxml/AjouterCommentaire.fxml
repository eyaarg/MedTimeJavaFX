<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.AjouterCommentaireController"
            style="-fx-background-color: #f5f5f5;">

    <children>

        <!-- Carte principale -->
        <Pane layoutX="50" layoutY="40" prefWidth="500" prefHeight="300"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2),10,0,0,2);">

            <children>

                <!-- Titre -->
                <Label text="Nouveau Commentaire"
                       layoutX="20" layoutY="15"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <!-- Ligne -->
                <Separator layoutX="20" layoutY="45" prefWidth="460"/>

                <!-- Contenu -->
                <Label text="Contenu"
                       layoutX="20" layoutY="65"/>
                <TextArea fx:id="txtContenu"
                          layoutX="20" layoutY="85"
                          prefWidth="460" prefHeight="80"
                          promptText="Tape ton commentaire ici..." />

                <!-- Article -->
                <Label text="Article"
                       layoutX="20" layoutY="180"/>
                <ComboBox fx:id="cbArticle"
                          layoutX="20" layoutY="200"
                          prefWidth="300"
                          promptText="Sélectionner un article" />

                <!-- Boutons -->
                <Button fx:id="btnAjouter"
                        text="Publier"
                        layoutX="260" layoutY="250"
                        prefWidth="100"
                        onAction="#ajouterCommentaire"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5;" />

                <Button fx:id="btnAnnuler"
                        text="Annuler"
                        layoutX="380" layoutY="250"
                        prefWidth="100"
                        onAction="#annuler"
                        style="-fx-background-color: transparent; -fx-border-color: #999; -fx-border-radius: 5;" />

            </children>
        </Pane>

    </children>
</AnchorPane>