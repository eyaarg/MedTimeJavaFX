<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.ModifierCommentaireController"
            style="-fx-background-color: #f5f5f5;">

    <children>

        <!-- Carte -->
        <Pane layoutX="40" layoutY="40" prefWidth="520" prefHeight="300"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2),10,0,0,2);">

            <children>

                <!-- Titre -->
                <Label text="Modifier Commentaire"
                       layoutX="20" layoutY="15"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <Separator layoutX="20" layoutY="45" prefWidth="480"/>

                <!-- Contenu -->
                <Label text="Contenu"
                       layoutX="20" layoutY="70"/>

                <TextArea fx:id="txtContenu"
                          layoutX="20" layoutY="90"
                          prefWidth="480" prefHeight="100"
                          promptText="Modifier le commentaire..." />

                <!-- Boutons -->
                <Button fx:id="btnModifier"
                        text="Enregistrer"
                        layoutX="260" layoutY="210"
                        prefWidth="100"
                        onAction="#modifierCommentaire"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5;" />

                <Button fx:id="btnAnnuler"
                        text="Annuler"
                        layoutX="380" layoutY="210"
                        prefWidth="100"
                        onAction="#annuler"
                        style="-fx-background-color: transparent; -fx-border-color: #999; -fx-border-radius: 5;" />

            </children>
        </Pane>

    </children>
</AnchorPane>