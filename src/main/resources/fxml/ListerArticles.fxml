<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.ArticleController"
            style="-fx-background-color: #f5f5f5;">

    <children>

        <!-- Header -->
        <Pane layoutX="30" layoutY="20" prefWidth="740" prefHeight="60"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2),5,0,0,2);">
            <children>
                <Label text="Forum Médical"
                       layoutX="20" layoutY="18"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                <Button fx:id="btnAjouter"
                        text="+ Ajouter"
                        layoutX="620" layoutY="15"
                        prefWidth="100"
                        onAction="#ajouterArticle"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5;" />
            </children>
        </Pane>

        <!-- ScrollPane avec FlowPane pour les cartes -->
        <ScrollPane layoutX="30" layoutY="100" prefWidth="740" prefHeight="450"
                    style="-fx-background: transparent;">
            <FlowPane fx:id="flowArticles" hgap="20" vgap="20" prefWrapLength="720">
                <padding>
                    <Insets top="10" left="10" bottom="10" right="10"/>
                </padding>
            </FlowPane>
        </ScrollPane>

    </children>
</AnchorPane>