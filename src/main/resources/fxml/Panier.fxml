<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.PanierController"
      spacing="0" style="-fx-background-color: #f0f4f8;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
        <padding><Insets top="20" right="32" bottom="20" left="32"/></padding>
        <Label text="🛒 Mon Panier" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblNbArticles" text="0 article(s)"
               style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
    </HBox>

    <!-- Liste des lignes -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
            <VBox fx:id="lignesContainer" spacing="12">
                <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>
            </VBox>
        </content>
    </ScrollPane>

    <!-- Footer total + boutons -->
    <VBox spacing="12"
          style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, -2, 0);">
        <padding><Insets top="20" right="32" bottom="20" left="32"/></padding>

        <Separator/>

        <HBox alignment="CENTER_RIGHT" spacing="16">
            <Label text="Total :" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
            <Label fx:id="lblTotal" text="0.00 TND"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="🗑 Vider le panier" onAction="#handleVider"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20;"/>
            <Button text="✅ Valider la commande" onAction="#handleValider"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24;"/>
        </HBox>
    </VBox>

</VBox>
