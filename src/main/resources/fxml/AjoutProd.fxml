<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.FormulaireProduitController"
      spacing="0" style="-fx-background-color:#f0f4f8;">

    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <padding><Insets top="28" right="32" bottom="20" left="32"/></padding>
        <VBox spacing="3">
            <Label fx:id="lblTitre" text="Ajouter un produit" styleClass="page-title"/>
            <Label text="Renseignez les informations du produit" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <content>
            <VBox spacing="16">
                <padding><Insets top="24" right="32" bottom="32" left="32"/></padding>

                <VBox spacing="16" styleClass="card-static">
                    <GridPane hgap="14" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                            <Label text="Nom" styleClass="field-label"/>
                            <TextField fx:id="txtNom" promptText="Ex: Paracétamol 500mg"
                                       maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <Label text="Catégorie" styleClass="field-label"/>
                            <ComboBox fx:id="cmbCategorie" promptText="Sélectionner une catégorie"
                                      maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="0">
                            <Label text="Prix (TND)" styleClass="field-label"/>
                            <TextField fx:id="txtPrix" promptText="Ex: 12.99"
                                       maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <Label text="Stock" styleClass="field-label"/>
                            <TextField fx:id="txtStock" promptText="Ex: 100"
                                       maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="0">
                            <Label text="Marque" styleClass="field-label"/>
                            <TextField fx:id="txtMarque" promptText="Ex: Doliprane"
                                       maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <Label text="Date d'expiration" styleClass="field-label"/>
                            <DatePicker fx:id="dpDateExpiration" promptText="JJ/MM/AAAA"
                                        maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="3" GridPane.columnIndex="0">
                            <Label text="Image (URL)" styleClass="field-label"/>
                            <TextField fx:id="txtImage" promptText="https://example.com/image.jpg"
                                       maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>

                        <VBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="1">
                            <Label text="Options" styleClass="field-label"/>
                            <VBox spacing="8">
                                <CheckBox fx:id="chkDisponible" text="Disponible à la vente" style="-fx-text-fill: #374151; -fx-font-size: 13px;"/>
                                <CheckBox fx:id="chkPrescription" text="Nécessite une ordonnance" style="-fx-text-fill: #374151; -fx-font-size: 13px;"/>
                            </VBox>
                        </VBox>

                        <VBox spacing="6" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2">
                            <Label text="Description" styleClass="field-label"/>
                            <TextArea fx:id="txtDescription" wrapText="true" prefRowCount="5"
                                      promptText="Description du produit..."
                                      maxWidth="Infinity" styleClass="form-input"/>
                        </VBox>
                    </GridPane>

                    <Separator/>

                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleAnnuler"/>
                        <Button fx:id="btnValider" text="➕" styleClass="btn-primary" onAction="#handleValider"/>
                    </HBox>
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

</VBox>
