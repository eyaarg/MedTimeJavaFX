<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="esprit.fx.controllers.FormulaireDisponibiliteController"
      spacing="15" style="-fx-background-color: #f8f9fa;" prefWidth="500" prefHeight="550">
   
   <padding>
      <Insets top="20" right="20" bottom="20" left="20" />
   </padding>

   <!-- Header -->
   <Label text="🕒 Formulaire Disponibilité" 
          style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
   
   <Separator />

   <!-- Formulaire -->
   <GridPane hgap="15" vgap="15">
      <columnConstraints>
         <ColumnConstraints minWidth="120" prefWidth="120" />
         <ColumnConstraints minWidth="300" prefWidth="300" hgrow="ALWAYS" />
      </columnConstraints>

      <!-- Médecin -->
      <Label text="Médecin :" GridPane.columnIndex="0" GridPane.rowIndex="0" 
             style="-fx-font-weight: bold;" />
      <ComboBox fx:id="comboDocteur" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                maxWidth="Infinity" promptText="Sélectionner un médecin" />

      <!-- Date de début -->
      <Label text="Date début :" GridPane.columnIndex="0" GridPane.rowIndex="1" 
             style="-fx-font-weight: bold;" />
      <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
         <DatePicker fx:id="datePickerDebut" promptText="Date de début" HBox.hgrow="ALWAYS" />
         <ComboBox fx:id="comboHeureDebut" promptText="Heure" prefWidth="80" />
      </HBox>

      <!-- Date de fin -->
      <Label text="Date fin :" GridPane.columnIndex="0" GridPane.rowIndex="2" 
             style="-fx-font-weight: bold;" />
      <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
         <DatePicker fx:id="datePickerFin" promptText="Date de fin" HBox.hgrow="ALWAYS" />
         <ComboBox fx:id="comboHeureFin" promptText="Heure" prefWidth="80" />
         <Button text="📅" onAction="#copierDateDebut" 
                 style="-fx-background-color: #3498db; -fx-text-fill: white;" 
                 tooltip="Copier la date de début" />
      </HBox>

      <!-- Statut -->
      <Label text="Statut :" GridPane.columnIndex="0" GridPane.rowIndex="3" 
             style="-fx-font-weight: bold;" />
      <CheckBox fx:id="checkBoxDisponible" text="Disponible" GridPane.columnIndex="1" GridPane.rowIndex="3" 
                style="-fx-font-size: 14px;" />

      <!-- Notes -->
      <Label text="Notes :" GridPane.columnIndex="0" GridPane.rowIndex="4" 
             style="-fx-font-weight: bold;" />
      <TextArea fx:id="textAreaNotes" GridPane.columnIndex="1" GridPane.rowIndex="4" 
                prefRowCount="4" promptText="Notes sur cette disponibilité (optionnel)..." 
                wrapText="true" />
   </GridPane>

   <!-- Spacer -->
   <Region VBox.vgrow="ALWAYS" />

   <!-- Boutons -->
   <HBox spacing="10" alignment="CENTER_RIGHT">
      <Button fx:id="btnAnnuler" text="❌ Annuler" onAction="#annuler" 
              style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" 
              prefWidth="100" />
      <Button fx:id="btnSauvegarder" text="💾 Sauvegarder" onAction="#sauvegarder" 
              style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" 
              prefWidth="120" />
   </HBox>

</VBox>