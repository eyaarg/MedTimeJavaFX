<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="esprit.fx.controllers.LoginController">

    <!-- Top Menu -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: white; -fx-padding: 15;">
            <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e4468;"
                   text="MedTime" />
            <Pane HBox.hgrow="ALWAYS" />
            <HBox spacing="25">
                <Button style="-fx-background-color: transparent; -fx-text-fill: #1e4468;" text="Accueil" />
                <Button style="-fx-background-color: transparent; -fx-text-fill: #1e4468;" text="À propos" />
                <Button style="-fx-background-color: transparent; -fx-text-fill: #1e4468;" text="Services" />
                <Button style="-fx-background-color: transparent; -fx-text-fill: #1e4468;" text="Médecins" />
                <Button style="-fx-background-color: transparent; -fx-text-fill: #1e4468;" text="Contact" />
            </HBox>
        </HBox>
    </top>

    <!-- Center Login Card -->
    <center>
        <StackPane style="-fx-background-color: #f2f6fa;">
            <VBox alignment="CENTER" spacing="30">
                <VBox alignment="CENTER" spacing="12"
                      style="-fx-background-color: white; -fx-padding: 40 60;
                             -fx-background-radius: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, 4);"
                      prefWidth="420">

                    <Text style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Bienvenue" />
                    <Text fill="#777" text="Connectez-vous à votre compte pour continuer" />

                    <Label alignment="CENTER_LEFT"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           text="Email" />
                    <TextField fx:id="usernameField"
                               promptText="Entrez votre email"
                               style="-fx-background-color: #edf2ff; -fx-background-radius: 25; -fx-padding: 8 15;"
                               maxWidth="Infinity"/>

                    <Label alignment="CENTER_LEFT"
                           style="-fx-font-weight: bold; -fx-font-size: 12px;"
                           text="Mot de passe" />
                    <PasswordField fx:id="passwordField"
                                   promptText="Entrez votre mot de passe"
                                   style="-fx-background-color: #edf2ff; -fx-background-radius: 25; -fx-padding: 8 15;"
                                   maxWidth="Infinity"/>

                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <CheckBox text="Se souvenir de moi" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Hyperlink text="Mot de passe oublié ?" />
                    </HBox>

                    <Button fx:id="signInButton"
                            text="Se connecter"
                            onAction="#handleLogin"
                            style="-fx-background-color: #197bff; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 25;
                                   -fx-padding: 10 60; -fx-cursor: hand;"
                            maxWidth="Infinity"/>

                    <Separator style="-fx-padding: 10;" />

                    <!-- Raccourcis développement -->
                    <VBox alignment="CENTER" spacing="8">
                        <Text fill="#888" style="-fx-font-size:11px;" text="Accès rapide (développement)" />
                        <HBox alignment="CENTER" spacing="10">
                            <Button text="👤 Patient"
                                    onAction="#loginAsPatient"
                                    style="-fx-background-color: #e9edf8; -fx-background-radius: 8;
                                           -fx-text-fill: #333; -fx-cursor: hand;"/>
                            <Button text="👨‍⚕️ Médecin"
                                    onAction="#loginAsDoctor"
                                    style="-fx-background-color: #e9edf8; -fx-background-radius: 8;
                                           -fx-text-fill: #333; -fx-cursor: hand;"/>
                            <Button text="🔧 Admin"
                                    onAction="#loginAsAdmin"
                                    style="-fx-background-color: #e9edf8; -fx-background-radius: 8;
                                           -fx-text-fill: #333; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
