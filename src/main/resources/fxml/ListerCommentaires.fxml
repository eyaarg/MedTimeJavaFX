<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.CommentaireController"
            style="-fx-background-color: #f5f5f5;">

    <children>

        <!-- Carte principale -->
        <Pane layoutX="30" layoutY="30" prefWidth="640" prefHeight="440"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2),10,0,0,2);">

            <children>

                <!-- Header -->
                <Label text="Gestion des Commentaires"
                       layoutX="20" layoutY="15"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                <Button fx:id="btnAjouter"
                        text="+ Ajouter"
                        layoutX="500" layoutY="12"
                        prefWidth="100"
                        onAction="#ajouterCommentaire"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5;" />

                <Separator layoutX="20" layoutY="45" prefWidth="600"/>

                <!-- Table -->
                <TableView fx:id="tableCommentaires"
                           layoutX="20" layoutY="60"
                           prefWidth="600" prefHeight="280">

                    <columns>
                        <TableColumn fx:id="colContenu" text="Contenu" prefWidth="300"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
                        <TableColumn fx:id="colLikes" text="Likes" prefWidth="100"/>
                    </columns>

                </TableView>

                <!-- Boutons -->
                <Button fx:id="btnModifier"
                        text="Modifier"
                        layoutX="350" layoutY="360"
                        prefWidth="100"
                        onAction="#modifierCommentaire"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5;" />

                <Button fx:id="btnSupprimer"
                        text="Supprimer"
                        layoutX="470" layoutY="360"
                        prefWidth="120"
                        onAction="#supprimerCommentaire"
                        style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5;" />

            </children>
        </Pane>

    </children>
</AnchorPane>