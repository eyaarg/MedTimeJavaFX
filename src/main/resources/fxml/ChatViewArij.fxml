<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.ChatControllerArij"
      spacing="0" stylesheets="@/fxml/css/arij-styles.css"
      style="-fx-background-color: #f0f4f8;">

    <!-- ── PAGE HEADER ─────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <padding><Insets top="28" right="32" bottom="20" left="32"/></padding>
        <VBox spacing="3">
            <Label text="Chat &amp; Assistant IA" styleClass="page-title"/>
            <Label text="Messagez votre médecin ou posez une question médicale à l'IA" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="32" bottom="28" left="32"/></padding>

        <!-- ── PANNEAU GAUCHE : Chat en direct ─────────────────────── -->
        <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="chat-panel">
            <VBox styleClass="chat-panel-header">
                <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                <Label text="💬  Chat en direct" styleClass="panel-title"/>
            </VBox>
            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-scroll">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <content>
                    <VBox fx:id="messagesBox" spacing="10"/>
                </content>
            </ScrollPane>
            <HBox spacing="10" styleClass="chat-input-bar">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                <TextField fx:id="messageInput" promptText="Écrire un message…"
                           HBox.hgrow="ALWAYS" styleClass="chat-input" onAction="#handleSend"/>
                <Button text="Envoyer →" styleClass="btn-primary" onAction="#handleSend"/>
            </HBox>
        </VBox>

        <!-- ── PANNEAU DROIT : Historique IA ───────────────────────── -->
        <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="chat-panel">

            <!-- Header IA -->
            <VBox style="-fx-background-color:#1e3a5f;-fx-padding:14 18 14 18;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🤖  Assistant Médical IA" styleClass="panel-title"
                           style="-fx-text-fill:white;-fx-font-size:14px;-fx-font-weight:bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="aiLoadingLabel" text="⏳ Réflexion…"
                           style="-fx-text-fill:#94a3b8;-fx-font-size:11px;"
                           visible="false" managed="false"/>
                </HBox>
                <!-- Chips de suggestions -->
                <HBox spacing="8" style="-fx-padding:10 0 0 0;">
                    <Button text="Expliquer le diagnostic" onAction="#presetExplain"
                            style="-fx-background-color:#2d5a8e;-fx-text-fill:white;
                                   -fx-font-size:11px;-fx-padding:5 10;
                                   -fx-background-radius:12;-fx-cursor:hand;"/>
                    <Button text="Effets secondaires" onAction="#presetSideEffects"
                            style="-fx-background-color:#2d5a8e;-fx-text-fill:white;
                                   -fx-font-size:11px;-fx-padding:5 10;
                                   -fx-background-radius:12;-fx-cursor:hand;"/>
                    <Button text="Prochaines étapes" onAction="#presetNextSteps"
                            style="-fx-background-color:#2d5a8e;-fx-text-fill:white;
                                   -fx-font-size:11px;-fx-padding:5 10;
                                   -fx-background-radius:12;-fx-cursor:hand;"/>
                </HBox>
            </VBox>

            <!-- Historique des messages IA -->
            <ScrollPane fx:id="aiScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-scroll">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <content>
                    <VBox fx:id="aiMessagesBox" spacing="10"/>
                </content>
            </ScrollPane>

            <!-- Zone de saisie IA -->
            <HBox spacing="10" styleClass="chat-input-bar">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                <TextField fx:id="aiInput" promptText="Posez une question médicale à l'IA…"
                           HBox.hgrow="ALWAYS" styleClass="chat-input" onAction="#handleAskAi"/>
                <Button text="Demander →" styleClass="btn-primary" onAction="#handleAskAi"/>
            </HBox>
        </VBox>

    </HBox>
</VBox>
