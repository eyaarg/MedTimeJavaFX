<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="esprit.fx.controllers.SplashControllerArij"
           style="-fx-background-color:white;"
           prefWidth="560" prefHeight="400">

    <VBox fx:id="splashRoot" alignment="CENTER" spacing="0" opacity="0">

        <!-- Logo -->
        <StackPane prefWidth="160" prefHeight="140">
            <Label fx:id="logoEmoji" text="💊"
                   style="-fx-font-size:100px; -fx-translate-x:-16; -fx-translate-y:-8;"/>
            <Label text="🕐"
                   style="-fx-font-size:64px; -fx-translate-x:34; -fx-translate-y:24;"/>
        </StackPane>

        <!-- Nom -->
        <Label text="MedTime"
               style="-fx-font-size:48px; -fx-font-weight:bold; -fx-text-fill:#0f172a;
                      -fx-font-family:'Segoe UI'; -fx-padding:0 0 4 0;"/>

        <!-- Sous-titre -->
        <Label text="Plateforme médicale intelligente"
               style="-fx-font-size:13px; -fx-text-fill:#64748b; -fx-padding:0 0 28 0;"/>

        <!-- Barre de progression -->
        <ProgressBar fx:id="progressBar" prefWidth="240" prefHeight="5" progress="0"
                     style="-fx-accent:#1d4ed8; -fx-background-color:#e2e8f0;
                            -fx-background-radius:999; -fx-border-radius:999;"/>

        <!-- Compteur -->
        <HBox alignment="CENTER" spacing="6" style="-fx-padding:8 0 0 0;">
            <Label text="Chargement"
                   style="-fx-font-size:12px; -fx-text-fill:#94a3b8;"/>
            <Label fx:id="countdownLabel" text="5s"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#1d4ed8;"/>
        </HBox>

    </VBox>

</StackPane>
