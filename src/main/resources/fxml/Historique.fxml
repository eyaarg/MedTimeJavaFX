<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.HistoriqueController"
      prefWidth="620" prefHeight="580"
      style="-fx-background-color: #f3f4f6;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #1e3a5f 0%, #2563eb 100%);
                 -fx-padding: 24 28;">
        <Label text="📋 Historique du Rendez-vous"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="labelRdvInfo"
               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.85); -fx-padding: 6 0 0 0;"
               wrapText="true"/>
    </VBox>

    <!-- Stats bar -->
    <HBox spacing="0"
          style="-fx-background-color: white;
                 -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">

        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-padding: 14; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 0 0;">
            <Label text="Changements"
                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af; -fx-font-weight: 600;"/>
            <Label fx:id="labelNbChangements" text="—"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #2563eb;"/>
        </VBox>

        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-padding: 14;">
            <Label text="Durée totale"
                   style="-fx-font-size: 11px; -fx-text-fill: #9ca3af; -fx-font-weight: 600;"/>
            <Label fx:id="labelDuree" text="—"
                   style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #059669;"/>
        </VBox>

    </HBox>

    <!-- Timeline scrollable -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: #f3f4f6;">
        <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
        <VBox fx:id="timelineContainer" spacing="4"/>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT"
          style="-fx-background-color: white; -fx-padding: 14 20;
                 -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
        <Button fx:id="btnFermer" text="✖ Fermer" onAction="#fermer"
                style="-fx-background-color: #6b7280; -fx-text-fill: white;
                       -fx-font-weight: 600; -fx-padding: 10 24;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

</VBox>
