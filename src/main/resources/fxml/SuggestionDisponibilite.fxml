    </VBox>

    <!-- Formulaire de recherche -->
    <VBox spacing="14"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">

        <HBox spacing="14" alignment="CENTER_LEFT">
            <!-- M√É¬©decin -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="√∞≈∏‚Äò¬®√¢‚Ç¨¬ç√¢≈°‚Ä¢√Ø¬∏¬è M√É¬©decin"
                       style="-fx-font-weight: 700; -fx-font-size: 13px; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="comboDocteur" maxWidth="Infinity"
