<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.consultationonline.ConsultationListControllerArij"
      spacing="10" stylesheets="@/css/consultationonline/arij-styles.css">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox spacing="10">
        <ComboBox fx:id="filterStatusCombo" promptText="Filter by status" prefWidth="150" onAction="#onStatusFilterChange"/>
        <ComboBox fx:id="filterTypeCombo" promptText="Filter by type" prefWidth="150" onAction="#onTypeFilterChange"/>
        <TextField fx:id="searchField" promptText="Search..." onKeyReleased="#onSearch"/>
        <Button text="New Consultation" fx:id="newConsultationButton" onAction="#openNewConsultation"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <content>
            <FlowPane fx:id="cardsContainer" hgap="12" vgap="12" prefWrapLength="800"/>
        </content>
    </ScrollPane>
</VBox>
