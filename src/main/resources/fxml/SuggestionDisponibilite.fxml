        <Label text="√∞≈∏‚Äô¬° Cr√É¬©neaux de 30 min √¢‚Ç¨‚Äù Algorithme de disponibilit√É¬© automatique"
               style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnFermer" text="√¢≈ì‚Äì Fermer" onAction="#fermer"
