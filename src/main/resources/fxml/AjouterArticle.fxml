<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.AjouterArticleController"
      spacing="0" stylesheets="@/css/arij-styles.css"
      style="-fx-background-color:#f0f4f8;">

    <!-- Header -->
    <VBox styleClass="hero-header">
        <padding><Insets top="22" right="32" bottom="18" left="32"/></padding>
        <Label text="➕  Ajouter un article" styleClass="hero-title" style="-fx-font-size:18px;"/>
        <Label text="Renseignez les informations de l'article" styleClass="hero-subtitle"/>
    </VBox>

    <VBox spacing="16" style="-fx-padding:28 32;">

        <VBox spacing="14" styleClass="card-static">

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Titre" styleClass="field-label"/>
                    <TextField fx:id="txtTitre" promptText="Entrer le titre"
                               maxWidth="Infinity" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <Label text="Catégorie" styleClass="field-label"/>
                    <ComboBox fx:id="cbCategorie" promptText="Choisir catégorie"
                              maxWidth="Infinity" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="0">
                    <Label text="Tags" styleClass="field-label"/>
                    <TextField fx:id="txtTags" promptText="ex: santé, médecine"
                               maxWidth="Infinity" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <Label text="Statut" styleClass="field-label"/>
                    <ComboBox fx:id="cbStatut" promptText="Choisir statut"
                              maxWidth="Infinity" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2">
                    <Label text="Image" styleClass="field-label"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="txtImage" promptText="https://... ou cliquez Générer"
                                   maxWidth="Infinity" styleClass="form-input"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnGenererImage" text="🎨 Générer"
                                onAction="#genererImage"
                                style="-fx-background-color:#7c3aed; -fx-text-fill:white;
                                       -fx-font-size:12px; -fx-font-weight:bold;
                                       -fx-background-radius:8; -fx-border-color:transparent;
                                       -fx-padding:8 14; -fx-cursor:hand;"/>
                    </HBox>
                    <!-- Prévisualisation de l'image générée -->
                    <HBox fx:id="previewBox" spacing="10" alignment="CENTER_LEFT"
                          visible="false" managed="false"
                          style="-fx-background-color:#faf5ff; -fx-background-radius:8;
                                 -fx-border-color:#e9d5ff; -fx-border-width:1; -fx-border-radius:8;
                                 -fx-padding:8 12;">
                        <Label fx:id="lblPreviewInfo" text=""
                               style="-fx-font-size:11px; -fx-text-fill:#7c3aed; -fx-wrap-text:true;"
                               maxWidth="380"/>
                    </HBox>
                </VBox>

                <VBox spacing="6" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2">
                    <Label text="Contenu" styleClass="field-label"/>
                    <TextArea fx:id="txtContenu" wrapText="true" prefRowCount="5"
                              promptText="Contenu de l'article..."
                              maxWidth="Infinity" styleClass="form-input"/>
                </VBox>
            </GridPane>

            <Separator/>

            <!-- ── Planification ── -->
            <VBox spacing="10"
                  style="-fx-background-color:#f0f9ff; -fx-background-radius:8;
                         -fx-border-color:#bae6fd; -fx-border-width:1; -fx-border-radius:8;
                         -fx-padding:12 14;">

                <CheckBox fx:id="chkPlanifier" text="🗓  Planifier la publication"
                          style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#0369a1;"
                          onAction="#togglePlanification"/>

                <HBox fx:id="panneauPlanification" spacing="16" alignment="CENTER_LEFT"
                      visible="false" managed="false">

                    <VBox spacing="4">
                        <Label text="Date de publication" styleClass="field-label"/>
                        <DatePicker fx:id="datePicker" promptText="Choisir une date"
                                    style="-fx-font-size:13px; -fx-background-radius:7; -fx-border-radius:7;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Heure" styleClass="field-label"/>
                        <ComboBox fx:id="cbHeure" promptText="Heure"
                                  style="-fx-font-size:13px; -fx-min-width:90px;"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Minutes" styleClass="field-label"/>
                        <ComboBox fx:id="cbMinutes" promptText="Min"
                                  style="-fx-font-size:13px; -fx-min-width:80px;"/>
                    </VBox>

                    <Label fx:id="lblPlanifInfo" text=""
                           style="-fx-font-size:11px; -fx-text-fill:#0369a1; -fx-wrap-text:true;"
                           maxWidth="200"/>
                </HBox>
            </VBox>

            <Separator/>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button fx:id="btnAnnuler" text="Annuler" styleClass="btn-secondary" onAction="#annuler"/>
                <Button fx:id="btnAjouter" text="➕ Publier" styleClass="btn-primary" onAction="#ajouterArticle"/>
            </HBox>

        </VBox>
    </VBox>

</VBox>
