<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.ConsultationListControllerArij"
      spacing="0" stylesheets="@/css/arij-styles.css"
      style="-fx-background-color: #f0f4f8;">

    <!-- Page header -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="page-header">
        <padding><Insets top="28" right="32" bottom="20" left="32"/></padding>
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Mes Consultations" styleClass="page-title"/>
            <Label text="Gérez et suivez tous vos rendez-vous médicaux" styleClass="page-subtitle"/>
        </VBox>
        <Button fx:id="newConsultationButton" text="+ Nouvelle Consultation"
                styleClass="btn-primary" onAction="#openNewConsultation"/>
    </HBox>

    <!-- Filters bar -->
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="14" right="32" bottom="14" left="32"/></padding>
        <Label text="Statut :" styleClass="filter-label"/>
        <ComboBox fx:id="filterStatusCombo" promptText="Tous les statuts" prefWidth="160"
                  onAction="#onStatusFilterChange" styleClass="filter-combo"/>
        <Label text="Type :" styleClass="filter-label"/>
        <ComboBox fx:id="filterTypeCombo" promptText="Tous les types" prefWidth="140"
                  onAction="#onTypeFilterChange" styleClass="filter-combo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="🔍  Rechercher une consultation…"
                   prefWidth="240" onKeyReleased="#onSearch" styleClass="search-field"/>
    </HBox>

    <!-- Cards grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>
        <content>
            <FlowPane fx:id="cardsContainer" hgap="16" vgap="16" prefWrapLength="900"/>
        </content>
    </ScrollPane>
</VBox>
