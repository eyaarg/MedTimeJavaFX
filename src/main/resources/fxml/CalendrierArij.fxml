<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.CalendrierControllerArij"
      stylesheets="@../css/arij-styles.css"
      style="-fx-background-color: #f0f4f8;"
      spacing="0">

    <!-- ═══════════════════════════════════════════════════
         EN-TÊTE
    ═══════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <padding><Insets top="20" right="28" bottom="16" left="28"/></padding>
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="📅  Calendrier des disponibilités" styleClass="page-title"/>
            <Label text="Cliquez sur un créneau vert pour prendre rendez-vous"
                   styleClass="page-subtitle"/>
        </VBox>
        <!-- Rafraîchissement manuel -->
        <Button fx:id="btnRefresh"
                text="🔄  Actualiser"
                styleClass="btn-secondary"
                onAction="#handleRefresh"
                style="-fx-font-size: 12px; -fx-padding: 7 14;"/>
    </HBox>

    <!-- ═══════════════════════════════════════════════════
         BARRE DE FILTRES
    ═══════════════════════════════════════════════════ -->
    <HBox spacing="16" alignment="CENTER_LEFT"
          style="-fx-background-color: white;
                 -fx-border-color: #e2e8f0;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 12 28 12 28;">

        <!-- Sélecteur de médecin -->
        <VBox spacing="4">
            <Label text="Médecin" styleClass="field-label"/>
            <ComboBox fx:id="medecinCombo"
                      promptText="Tous les médecins"
                      prefWidth="220"
                      onAction="#handleMedecinChange"
                      style="-fx-background-color: #f8fafc;
                             -fx-border-color: #cbd5e1;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-font-size: 13px;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Légende -->
        <HBox spacing="16" alignment="CENTER">
            <HBox spacing="6" alignment="CENTER">
                <Label text="●" style="-fx-text-fill: #16a34a; -fx-font-size: 16px;"/>
                <Label text="Disponible" style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER">
                <Label text="●" style="-fx-text-fill: #dc2626; -fx-font-size: 16px;"/>
                <Label text="Occupé" style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER">
                <Label text="●" style="-fx-text-fill: #2563eb; -fx-font-size: 16px;"/>
                <Label text="Consultation" style="-fx-font-size: 12px; -fx-text-fill: #475569;"/>
            </HBox>
        </HBox>

        <!-- Indicateur de rafraîchissement -->
        <Label fx:id="lblRefreshStatus"
               text="⏱ Rafraîchissement auto : 60s"
               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
    </HBox>

    <!-- ═══════════════════════════════════════════════════
         ZONE CALENDRIER (CalendarFX injecté dynamiquement)
    ═══════════════════════════════════════════════════ -->
    <StackPane fx:id="calendarContainer"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: white;
                      -fx-padding: 0;"/>

</VBox>
