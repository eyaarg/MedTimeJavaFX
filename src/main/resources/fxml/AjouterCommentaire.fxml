<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.AjouterCommentaireController"
      spacing="0" stylesheets="@/fxml/css/arij-styles.css"
      style="-fx-background-color:#f0f4f8;">

    <!-- Header -->
    <VBox styleClass="hero-header">
        <padding><Insets top="22" right="32" bottom="18" left="32"/></padding>
        <Label text="💬  Nouveau commentaire" styleClass="hero-title" style="-fx-font-size:18px;"/>
        <Label text="Répondez à un article du forum" styleClass="hero-subtitle"/>
    </VBox>

    <VBox spacing="16" style="-fx-padding:28 32;">
        <VBox spacing="14" styleClass="card-static">

            <VBox spacing="6">
                <Label text="Article" styleClass="field-label"/>
                <ComboBox fx:id="cbArticle" promptText="Sélectionner un article"
                          maxWidth="Infinity" styleClass="form-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Commentaire" styleClass="field-label"/>
                <TextArea fx:id="txtContenu" wrapText="true" prefRowCount="5"
                          promptText="Tapez votre commentaire ici..."
                          maxWidth="Infinity" styleClass="form-input"/>
            </VBox>

            <Separator/>

            <HBox alignment="CENTER_RIGHT" spacing="12">
                <Button fx:id="btnAnnuler" text="Annuler" styleClass="btn-secondary" onAction="#annuler"/>
                <Button fx:id="btnAjouter" text="💬 Publier" styleClass="btn-primary" onAction="#ajouterCommentaire"/>
            </HBox>

        </VBox>
    </VBox>

</VBox>
