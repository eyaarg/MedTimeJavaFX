<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.NotificationPanelControllerArij"
      spacing="15" style="-fx-padding:20;-fx-background-color:#f5f5f5;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🔔 Notifications" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1565c0;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Loading Indicator -->
    <StackPane prefHeight="200">
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="60" prefHeight="60"/>
    </StackPane>

    <!-- Notifications Container -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color:transparent;-fx-border-color:transparent;">
        <VBox fx:id="notificationsContainer" spacing="12" style="-fx-background-color:transparent;"/>
    </ScrollPane>

    <!-- No Notifications Label -->
    <Label fx:id="noNotificationsLabel" text="Aucune notification"
           style="-fx-font-size:14px;-fx-text-fill:#999;-fx-text-alignment:center;"
           visible="false" managed="false"/>

</VBox>
