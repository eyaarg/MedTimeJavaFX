<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.SuggestionController"
      prefWidth="560" prefHeight="620"
      style="-fx-background-color: #f3f4f6;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #4f46e5 0%, #7c3aed 100%);
