<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.consultationonline.MainControllerArij"
            stylesheets="@/css/consultationonline/arij-styles.css"
            prefWidth="1100" prefHeight="700">

    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="0">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" alignment="CENTER" spacing="4">
                <padding><Insets top="22" bottom="18" left="20" right="20"/></padding>
                <Label text="MedTime" styleClass="brand-name"/>
                <Label text="Santé en ligne" styleClass="brand-sub"/>
            </VBox>

            <Separator styleClass="sidebar-sep"/>

            <Label text="MENU PRINCIPAL" styleClass="nav-section-label">
                <padding><Insets top="18" bottom="6" left="20" right="20"/></padding>
            </Label>

            <VBox spacing="4">
                <padding><Insets left="12" right="12"/></padding>
                <Button fx:id="btnConsultations" text="  Mes Consultations"
                        styleClass="nav-btn,nav-btn-active"
                        onAction="#showMyConsultations" maxWidth="Infinity"/>
                <Button fx:id="btnBook" text="  Prendre Rendez-vous"
                        styleClass="nav-btn"
                        onAction="#showBookAppointment" maxWidth="Infinity"/>
                <Button fx:id="btnPrescriptions" text="  Ordonnances"
                        styleClass="nav-btn"
                        onAction="#showPrescriptions" maxWidth="Infinity"/>
                <Button fx:id="btnInvoices" text="  Factures"
                        styleClass="nav-btn"
                        onAction="#showInvoices" maxWidth="Infinity"/>
                <Button fx:id="btnNotifications" text="  Notifications"
                        styleClass="nav-btn"
                        onAction="#showNotifications" maxWidth="Infinity"/>
            </VBox>

            <Separator styleClass="sidebar-sep">
                <VBox.margin><Insets top="12" bottom="4"/></VBox.margin>
            </Separator>

            <Label text="ANALYTIQUES" styleClass="nav-section-label">
                <padding><Insets top="6" bottom="6" left="20" right="20"/></padding>
            </Label>

            <VBox spacing="4">
                <padding><Insets left="12" right="12"/></padding>
                <Button fx:id="btnDashboard" text="  Tableau de bord"
                        styleClass="nav-btn"
                        onAction="#showDashboard" maxWidth="Infinity"/>
                <Button fx:id="btnChat" text="  Chat &amp; IA"
                        styleClass="nav-btn"
                        onAction="#showChatAi" maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-sep"/>

            <HBox styleClass="sidebar-footer" alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="16" bottom="20" left="16" right="16"/></padding>
                <StackPane styleClass="avatar-wrap">
                    <Label text="A" styleClass="avatar-label"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Arij Ben Ali" styleClass="footer-name"/>
                    <Label text="Patient" styleClass="footer-role"/>                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⏻" styleClass="logout-btn" onAction="#handleLogout"/>
            </HBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER"/>
    </center>

</BorderPane>
