<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.ChatControllerArij"
      spacing="0" stylesheets="@/css/arij-styles.css"
      style="-fx-background-color: #f0f4f8;">

    <HBox alignment="CENTER_LEFT" styleClass="page-header">
        <padding><Insets top="28" right="32" bottom="20" left="32"/></padding>
        <VBox spacing="3">
            <Label text="Chat &amp; Assistant IA" styleClass="page-title"/>
            <Label text="Messagez votre médecin ou posez une question médicale à l'IA" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="32" bottom="28" left="32"/></padding>

        <!-- Chat panel -->
        <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="chat-panel">
            <VBox styleClass="chat-panel-header">
                <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                <Label text="💬  Chat en direct" styleClass="panel-title"/>
            </VBox>
            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-scroll">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <content>
                    <VBox fx:id="messagesBox" spacing="10"/>
                </content>
            </ScrollPane>
            <HBox spacing="10" styleClass="chat-input-bar">
                <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                <TextField fx:id="messageInput" promptText="Écrire un message…"
                           HBox.hgrow="ALWAYS" styleClass="chat-input" onAction="#handleSend"/>
                <Button text="Envoyer →" styleClass="btn-primary" onAction="#handleSend"/>
            </HBox>
        </VBox>

        <!-- AI panel -->
        <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="chat-panel">
            <VBox styleClass="ai-panel-header">
                <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
                <Label text="🤖  Assistant Médical IA" styleClass="panel-title"/>
            </VBox>
            <VBox spacing="14" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
                <padding><Insets top="16" right="18" bottom="18" left="18"/></padding>
                <TextArea fx:id="questionInput" prefRowCount="4" styleClass="form-input"
                          promptText="Posez une question médicale…"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button text="Expliquer le diagnostic" styleClass="chip-btn" onAction="#presetExplain"/>
                    <Button text="Effets secondaires" styleClass="chip-btn" onAction="#presetSideEffects"/>
                    <Button text="Prochaines étapes" styleClass="chip-btn" onAction="#presetNextSteps"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Button text="Demander à l'IA" styleClass="btn-primary" onAction="#handleAskAi"/>
                    <Label fx:id="loadingLabel" text="⏳  Réflexion en cours…" styleClass="muted"
                           visible="false" managed="false"/>
                </HBox>
                <Label text="Réponse" styleClass="field-label"/>
                <TextArea fx:id="aiResponse" editable="false" prefRowCount="10"
                          styleClass="ai-response" wrapText="true"
                          promptText="La réponse de l'IA apparaîtra ici…"/>
            </VBox>
        </VBox>

    </HBox>
</VBox>
