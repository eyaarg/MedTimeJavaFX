<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.ListeFavorisController"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="❤️ Mes Favoris"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
        <Button text="← Retour aux produits" onAction="#handleRetour"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 6 16;"/>
    </HBox>

    <Label fx:id="lblVide" text="Aucun favori pour le moment."
           style="-fx-text-fill: #95a5a6; -fx-font-size: 14px;" visible="false" managed="false"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <FlowPane fx:id="cardsContainer" hgap="15" vgap="15" alignment="TOP_LEFT"
                  style="-fx-background-color: transparent;"/>
    </ScrollPane>

    <Label fx:id="lblStatus" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>

</VBox>
