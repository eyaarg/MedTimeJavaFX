<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.ChatbotControllerArij"
            stylesheets="@../css/arij-styles.css"
            style="-fx-background-color: #f0f4f8;">

    <!-- ═══════════════════════════════════════════════════
         TOP HEADER
    ═══════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="page-header">
            <padding><Insets top="22" right="28" bottom="18" left="28"/></padding>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label text="🩺  MediAssist — Chatbot Médical IA" styleClass="page-title"/>
                <Label text="Posez vos questions de santé, consultez votre historique de conversations"
                       styleClass="page-subtitle"/>
            </VBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════
         MAIN CONTENT
    ═══════════════════════════════════════════════════ -->
    <center>
        <HBox spacing="0" style="-fx-background-color: #f0f4f8;">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- ─────────────────────────────────────────
                 LEFT PANEL — Sessions
            ───────────────────────────────────────── -->
            <VBox spacing="0" prefWidth="260" minWidth="220"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12 0 0 12;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1 0 1 1;
                         -fx-border-radius: 12 0 0 12;">

                <!-- Sessions header -->
                <VBox style="-fx-background-color: #0f172a;
                             -fx-background-radius: 12 0 0 0;
                             -fx-padding: 14 16 14 16;">
                    <Label text="💬  Conversations" styleClass="panel-title"/>
                    <Label text="Historique des sessions" styleClass="muted"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
                </VBox>

                <!-- New session button -->
                <HBox style="-fx-padding: 10 12 8 12;">
                    <Button fx:id="newSessionButton" text="＋  Nouvelle conversation"
                            onAction="#handleNewSession"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            styleClass="btn-primary"
                            style="-fx-font-size: 12px; -fx-padding: 8 12 8 12;"/>
                </HBox>

                <!-- Sessions list -->
                <ListView fx:id="sessionListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent;
                                 -fx-border-color: transparent;
                                 -fx-padding: 0 6 0 6;
                                 -fx-font-size: 12px;"/>

                <!-- Delete session button -->
                <HBox style="-fx-padding: 8 12 12 12;
                             -fx-border-color: #f1f5f9;
                             -fx-border-width: 1 0 0 0;">
                    <Button fx:id="deleteSessionButton" text="🗑  Supprimer la session"
                            onAction="#handleDeleteSession"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            styleClass="btn-action-delete action-btn"
                            style="-fx-font-size: 12px; -fx-padding: 8 12 8 12;"/>
                </HBox>
            </VBox>

            <!-- ─────────────────────────────────────────
                 RIGHT PANEL — Chat
            ───────────────────────────────────────── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 0 12 12 0;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1;
                         -fx-border-radius: 0 12 12 0;">

                <!-- Chat header -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #1d4ed8;
                             -fx-background-radius: 0 12 0 0;
                             -fx-padding: 14 18 14 18;">
                    <Label text="🩺" style="-fx-font-size: 20px;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="sessionTitleLabel" text="Sélectionnez une session"
                               styleClass="panel-title"/>
                        <Label text="MediAssist • Assistant médical IA"
                               style="-fx-text-fill: #bfdbfe; -fx-font-size: 11px;"/>
                    </VBox>
                    <!-- Online indicator -->
                    <HBox alignment="CENTER" spacing="5">
                        <Label text="●" style="-fx-text-fill: #4ade80; -fx-font-size: 10px;"/>
                        <Label text="En ligne" style="-fx-text-fill: #bfdbfe; -fx-font-size: 11px;"/>
                    </HBox>
                </HBox>

                <!-- Messages area -->
                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: #f8fafc;
                                   -fx-background: #f8fafc;
                                   -fx-border-color: transparent;">
                    <content>
                        <VBox fx:id="messagesBox" spacing="10">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Typing indicator + ProgressIndicator -->
                <!-- Visible uniquement pendant l'appel API (géré par showLoading()) -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 4 18 4 18;">

                    <!-- ProgressIndicator (spinner circulaire JavaFX)
                         • visible=false  : caché par défaut
                         • managed=false  : ne prend pas de place quand caché
                         • showLoading(true) les passe à true pendant le Task -->
                    <ProgressIndicator fx:id="loadingSpinner"
                                       prefWidth="18" prefHeight="18"
                                       visible="false" managed="false"
                                       style="-fx-progress-color: #2563eb;"/>

                    <Label fx:id="typingIndicator"
                           text="MediAssist est en train d'écrire…"
                           visible="false" managed="false"
                           style="-fx-text-fill: #64748b;
                                  -fx-font-size: 11px;
                                  -fx-font-style: italic;"/>
                </HBox>

                <!-- Input bar -->
                <HBox spacing="10" alignment="CENTER"
                      style="-fx-background-color: white;
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1 0 0 0;
                             -fx-padding: 12 16 12 16;">
                    <TextField fx:id="messageInput"
                               promptText="Décrivez vos symptômes ou posez une question…"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #f1f5f9;
                                      -fx-border-color: transparent;
                                      -fx-background-radius: 22;
                                      -fx-border-radius: 22;
                                      -fx-padding: 10 16 10 16;
                                      -fx-font-size: 13px;"/>
                    <Button fx:id="sendButton" text="Envoyer →"
                            onAction="#handleSend"
                            styleClass="btn-primary"
                            style="-fx-padding: 10 20 10 20;"/>
                </HBox>

            </VBox>
        </HBox>
    </center>

</BorderPane>
