<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.CalendrierControllerArij"
      spacing="15" style="-fx-padding: 15; -fx-background-color: #f5f5f5;">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- HEADER: Titre et KPIs -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <Label text="📅 Calendrier des Disponibilités" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        
        <HBox spacing="20" alignment="CENTER_LEFT">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Créneaux libres" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="creneauxLibresLabel" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
            </VBox>
            
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Consultations" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="consultationsLabel" text="0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
            </VBox>
            
            <Button fx:id="addCreneauBtn" text="➕ Ajouter créneau" 
                    style="-fx-padding: 10 20; -fx-font-size: 12; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand; -fx-border-radius: 5;"/>
        </HBox>
    </VBox>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- CALENDRIER -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        
        <!-- Navigation -->
        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="prevMonthBtn" text="◀ Précédent" style="-fx-padding: 8 15; -fx-font-size: 11; -fx-cursor: hand;"/>
            <Label fx:id="monthYearLabel" text="Avril 2026" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-min-width: 150; -fx-text-alignment: center;"/>
            <Button fx:id="nextMonthBtn" text="Suivant ▶" style="-fx-padding: 8 15; -fx-font-size: 11; -fx-cursor: hand;"/>
            <Button fx:id="todayBtn" text="Aujourd'hui" style="-fx-padding: 8 15; -fx-font-size: 11; -fx-cursor: hand;"/>
        </HBox>
        
        <!-- Grille du calendrier -->
        <GridPane fx:id="calendarGrid" hgap="1" vgap="1" style="-fx-border-color: #e0e0e0; -fx-border-width: 1;"/>
        
        <!-- Indicateur de chargement -->
        <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false" prefWidth="50" prefHeight="50"/>
    </VBox>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- LÉGENDE -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <VBox fx:id="legendeBox" spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>

</VBox>
