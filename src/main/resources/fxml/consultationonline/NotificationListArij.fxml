<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.consultationonline.NotificationListControllerArij"
      spacing="10" stylesheets="@/css/consultationonline/arij-styles.css">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Button text="Mark all as read" onAction="#markAllRead"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="notificationsContainer" spacing="8"/>
        </content>
    </ScrollPane>
</VBox>
