<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="esprit.fx.controllers.SecuriteControllerArij"
            style="-fx-font-family: 'Segoe UI'; -fx-font-size: 11;">
    
    <!-- TOP: Titre -->
    <top>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #f5f5f5; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <Label text="🔐 Statut de la Sécurité" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <Label text="Gestion du chiffrement des données médicales" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
        </VBox>
    </top>
    
    <!-- CENTER: Contenu -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true">
            <VBox spacing="20" style="-fx-padding: 20;">
                
                <!-- Statut Chiffrement -->
                <TitledPane text="📊 Statut du Chiffrement" expanded="true">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <TableView fx:id="tableStatut" prefHeight="200">
                            <columns>
                                <TableColumn text="Champ" prefWidth="200"/>
                                <TableColumn text="Statut" prefWidth="200"/>
                            </columns>
                        </TableView>
                    </VBox>
                </TitledPane>
                
                <!-- Test Chiffrement -->
                <TitledPane text="🧪 Test du Chiffrement" expanded="true">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <Button fx:id="btnTesterChiffrement" text="Tester le chiffrement" 
                                style="-fx-font-size: 12; -fx-padding: 10; -fx-background-color: #2196F3; -fx-text-fill: white;"/>
                        <TextArea fx:id="textAreaTest" prefHeight="150" wrapText="true" editable="false"/>
                    </VBox>
                </TitledPane>
                
                <!-- Configuration -->
                <TitledPane text="⚙️ Configuration" expanded="true">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10">
                            <Label text="Algorithme :" style="-fx-font-weight: bold;"/>
                            <Label fx:id="labelAlgorithme" text="PBEWithMD5AndDES"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Clé secrète :" style="-fx-font-weight: bold;"/>
                            <Label fx:id="labelCle" text="••••••••••"/>
                        </HBox>
                    </VBox>
                </TitledPane>
                
            </VBox>
        </ScrollPane>
    </center>
    
</BorderPane>
