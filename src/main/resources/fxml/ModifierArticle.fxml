<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="520.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="esprit.fx.controllers.ModifierArticleController"
            style="-fx-background-color: #f5f5f5;">

    <children>

        <!-- Carte -->
        <Pane layoutX="40" layoutY="30" prefWidth="620" prefHeight="460"
              style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2),10,0,0,2);">

            <children>

                <!-- Titre -->
                <Label text="Modifier Article"
                       layoutX="20" layoutY="15"
                       style="-fx-font-size: 20px; -fx-font-weight: bold;" />

                <Separator layoutX="20" layoutY="45" prefWidth="580"/>

                <!-- Titre -->
                <Label text="Titre"
                       layoutX="20" layoutY="70"/>
                <TextField fx:id="txtTitre"
                           layoutX="20" layoutY="90"
                           prefWidth="250"
                           promptText="Modifier le titre"/>

                <!-- Catégorie -->
                <Label text="Catégorie"
                       layoutX="320" layoutY="70"/>
                <ComboBox fx:id="cbCategorie"
                          layoutX="320" layoutY="90"
                          prefWidth="250"
                          promptText="Choisir catégorie"/>

                <!-- Contenu -->
                <Label text="Contenu"
                       layoutX="20" layoutY="140"/>
                <TextArea fx:id="txtContenu"
                          layoutX="20" layoutY="160"
                          prefWidth="550" prefHeight="80"
                          promptText="Modifier le contenu"/>

                <!-- Tags -->
                <Label text="Tags"
                       layoutX="20" layoutY="260"/>
                <TextField fx:id="txtTags"
                           layoutX="20" layoutY="280"
                           prefWidth="250"
                           promptText="ex: java, santé"/>

                <!-- Statut -->
                <Label text="Statut"
                       layoutX="320" layoutY="260"/>
                <ComboBox fx:id="cbStatut"
                          layoutX="320" layoutY="280"
                          prefWidth="250"
                          promptText="Choisir statut"/>

                <!-- Image -->
                <Label text="Image URL"
                       layoutX="20" layoutY="320"/>
                <TextField fx:id="txtImage"
                           layoutX="20" layoutY="340"
                           prefWidth="550"
                           promptText="Lien de l'image"/>

                <!-- Boutons -->
                <Button fx:id="btnModifier"
                        text="Enregistrer"
                        layoutX="350" layoutY="390"
                        prefWidth="100"
                        onAction="#modifierArticle"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5;" />

                <Button fx:id="btnAnnuler"
                        text="Annuler"
                        layoutX="470" layoutY="390"
                        prefWidth="100"
                        onAction="#annuler"
                        style="-fx-background-color: transparent; -fx-border-color: #999; -fx-border-radius: 5;" />

            </children>
        </Pane>

    </children>
</AnchorPane>