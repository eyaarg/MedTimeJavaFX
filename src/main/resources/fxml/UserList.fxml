<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.UserListController"
      spacing="0"
      style="-fx-background-color: #F5F7FA;">
    <stylesheets>
        <URL value="@../css/arij-styles.css"/>
    </stylesheets>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: white; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="20" right="28" bottom="16" left="28"/></padding>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Gestion des utilisateurs"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E;"/>
            <Label text="Gérez les comptes, validez les médecins, débloquez les accès"
                   style="-fx-font-size: 12px; -fx-text-fill: #9E9E9E;"/>
        </VBox>
        <Button text="+ Ajouter" onAction="#openAddUserDialog"
                style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
        <Button text="↻ Rafraîchir" onAction="#refreshUsers"
                style="-fx-background-color: #F5F5F5; -fx-text-fill: #424242; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
    </HBox>

    <!-- BARRE DE FILTRES -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: white; -fx-border-color: #EEEEEE; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="12" right="28" bottom="12" left="28"/></padding>
        <TextField fx:id="searchField" promptText="🔍  Rechercher par nom ou email..."
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E0E0E0; -fx-padding: 7 12 7 12;"
                   prefWidth="260" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="roleFilterComboBox" prefWidth="140"
                  style="-fx-background-radius: 8;"/>
        <ComboBox fx:id="statusFilterComboBox" prefWidth="150"
                  style="-fx-background-radius: 8;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="resultCountLabel" text="0 utilisateur(s)"
               style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
    </HBox>

    <!-- LISTE DE CARTES -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <padding><Insets top="16" right="28" bottom="24" left="28"/></padding>
        <content>
            <VBox fx:id="cardsContainer" spacing="10"
                  style="-fx-background-color: transparent;"/>
        </content>
    </ScrollPane>

</VBox>
