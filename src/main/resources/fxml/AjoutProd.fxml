<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="esprit.fx.controllers.FormulaireProduitController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Titre -->
    <Label fx:id="lblTitre" text="Ajouter un produit" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>

    <Separator/>

    <!-- Formulaire avec tous les champs -->
    <ScrollPane fitToWidth="true" prefHeight="500">
        <GridPane hgap="15" vgap="12">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 1. Nom -->
            <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtNom" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="Ex: Paracétamol 500mg" prefWidth="400"/>

            <!-- 2. Description -->
            <Label text="Description :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="txtDescription" GridPane.rowIndex="1" GridPane.columnIndex="1" prefHeight="80" promptText="Description du produit..."/>

            <!-- 3. Catégorie -->
            <Label text="Catégorie :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbCategorie" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Sélectionner une catégorie"/>

            <!-- 4. Prix -->
            <Label text="Prix (€) :" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtPrix" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Ex: 12.99"/>

            <!-- 5. Stock -->
            <Label text="Stock :" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtStock" GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="Ex: 100"/>

            <!-- 6. Image -->
            <Label text="Image URL :" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtImage" GridPane.rowIndex="5" GridPane.columnIndex="1" promptText="https://example.com/image.jpg"/>

            <!-- 7. Disponible -->
            <Label text="Disponible :" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <CheckBox fx:id="chkDisponible" GridPane.rowIndex="6" GridPane.columnIndex="1" text="Oui, disponible à la vente"/>

            <!-- 8. Prescription requise -->
            <Label text="Prescription :" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <CheckBox fx:id="chkPrescription" GridPane.rowIndex="7" GridPane.columnIndex="1" text="Nécessite une ordonnance"/>

            <!-- 9. Marque -->
            <Label text="Marque :" GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtMarque" GridPane.rowIndex="8" GridPane.columnIndex="1" promptText="Ex: Doliprane"/>

            <!-- 10. Date d'expiration -->
            <Label text="Date expiration :" GridPane.rowIndex="9" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
            <DatePicker fx:id="dpDateExpiration" GridPane.rowIndex="9" GridPane.columnIndex="1" promptText="JJ/MM/AAAA" prefWidth="200"/>

        </GridPane>
    </ScrollPane>

    <Separator/>

    <!-- Boutons -->
    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="btnValider" text="✅ Valider" onAction="#handleValider"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"
                prefWidth="120" prefHeight="35"/>
        <Button text=" Annuler" onAction="#handleAnnuler"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px;"
                prefWidth="120" prefHeight="35"/>
    </HBox>

</VBox>