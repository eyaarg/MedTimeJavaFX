                <Label text="√∞≈∏‚Ä¢¬ê Plage horaire"
                       style="-fx-font-weight: 700; -fx-font-size: 13px; -fx-text-fill: #374151;"/>
                <ComboBox fx:id="comboPlage" prefWidth="140"
                          style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-padding: 8; -fx-font-size: 13px;"/>
            </VBox>
        </HBox>

        <HBox spacing="14" alignment="BOTTOM_LEFT">
            <!-- Semaine -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
